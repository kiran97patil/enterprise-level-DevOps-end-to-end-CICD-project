pipeline {
    agent any

    tools {
        maven 'Maven-3'
    }

    environment {
        SONAR_PROJECT_KEY  = 'devops-masterpiece'
        SONAR_PROJECT_NAME = 'DevOps MasterPiece CI with Jenkins'
        SONAR_HOST_URL     = 'http://sonarqube:9000'

        DOCKER_IMAGE = 'insure-me'    // local image name
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build with Maven') {
            steps {
                sh 'mvn clean package'
            }
        }

        /* ---------------- SonarQube (TEMPORARILY DISABLED) ----------------

        stage('SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh '''
                      mvn sonar:sonar \
                        -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                        -Dsonar.projectName="$SONAR_PROJECT_NAME" \
                        -Dsonar.host.url=$SONAR_HOST_URL \
                        -Dsonar.login=$SONAR_TOKEN
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh '''
                      echo "Checking SonarQube Quality Gate status..."

                      RESPONSE=$(curl -s -u $SONAR_TOKEN: $SONAR_HOST_URL/api/qualitygates/project_status?projectKey=$SONAR_PROJECT_KEY)
                      echo "API response: $RESPONSE"

                      STATUS=$(echo "$RESPONSE" | grep -o '"status":"[^"]*"' | head -1 | cut -d':' -f2 | tr -d '"')
                      echo "Quality Gate status: $STATUS"

                      if [ "$STATUS" != "OK" ]; then
                        echo "Quality Gate FAILED: $STATUS"
                        exit 1
                      fi
                    '''
                }
            }
        }

        ---------------- SonarQube (TEMPORARILY DISABLED) ---------------- */

        stage('Upload Jar to Artifactory') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'artifactory-creds',
                                                 usernameVariable: 'ART_USER',
                                                 passwordVariable: 'ART_PASS')]) {
                    sh '''
                      echo "Uploading JAR to Artifactory..."

                      # Artifactory host (NodePort on Rancher Desktop)
                      ART_HOST="http:// 192.168.127.2 :32002"   # yahan apna actual INTERNAL-IP daalo

                      # Local repo name (update if different)
                      REPO="generic-local"

                      # Jar file path from Maven build
                      FILE="target/insure-me-1.0.jar"

                      # Path inside Artifactory repo
                      TARGET_PATH="insure-me/${BUILD_NUMBER}/insure-me-${BUILD_NUMBER}.jar"

                      echo "Uploading ${FILE} to ${ART_HOST}/artifactory/${REPO}/${TARGET_PATH}"

                      curl -v -u ${ART_USER}:${ART_PASS} \
                        -T ${FILE} \
                        "${ART_HOST}/artifactory/${REPO}/${TARGET_PATH}"
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                  echo "Building Docker image insure-me:jenkins ..."
                  docker build -t insure-me:jenkins .
                '''
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                sh '''
                  echo "Running Trivy scan on image insure-me:jenkins ..."

                  docker run --rm \
                    -v /var/run/docker.sock:/var/run/docker.sock \
                    -v trivy-cache:/root/.cache/ \
                    aquasec/trivy:0.50.2 image \
                    --timeout 10m \
                    --scanners vuln \
                    --exit-code 0 \
                    --severity HIGH,CRITICAL \
                    insure-me:jenkins
                '''
            }
        }

        stage('Docker Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds',
                                                 usernameVariable: 'DH_USER',
                                                 passwordVariable: 'DH_PASS')]) {
                    sh '''
                      echo "Logging in to Docker Hub..."
                      echo "$DH_PASS" | docker login -u "$DH_USER" --password-stdin

                      echo "Tagging images..."
                      docker tag insure-me:jenkins $DH_USER/insure-me:${BUILD_NUMBER}
                      docker tag insure-me:jenkins $DH_USER/insure-me:latest

                      echo "Pushing image tags to Docker Hub..."
                      docker push $DH_USER/insure-me:${BUILD_NUMBER}
                      docker push $DH_USER/insure-me:latest
                    '''
                }
            }
        }

        stage('Update K8s Manifests Repo') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-kiran',
                                                 usernameVariable: 'GIT_USER',
                                                 passwordVariable: 'GIT_TOKEN')]) {
                    sh '''
                      echo "Cloning manifests repo..."
                      rm -rf manifests-repo
                      git clone https://${GIT_USER}:${GIT_TOKEN}@github.com/kiran97patil/insure-me-k8s-manifests.git manifests-repo

                      cd manifests-repo/k8s

                      NEW_TAG=${BUILD_NUMBER}
                      echo "Updating image tag in deployment.yaml to kirankhode/insure-me:${NEW_TAG} ..."

                      sed -i "s#image: kirankhode/insure-me:.*#image: kirankhode/insure-me:${NEW_TAG}#g" deployment.yaml

                      echo "Git diff after change:"
                      git diff || true

                      git config user.email "narendrakhode1990@gmail.com"
                      git config user.name "narendra khode"

                      git commit -am "Update image tag to ${NEW_TAG} from Jenkins build ${BUILD_NUMBER}" || echo "No changes to commit"
                      git push origin main
                    '''
                }
            }
        }

        stage('Deploy Container (Local Docker)') {
            steps {
                sh '''
                    docker stop insure-me-app || true
                    docker rm insure-me-app || true
                    docker run -d --name insure-me-app -p 8082:8081 insure-me:jenkins
                '''
            }
        }
    }

    post {
        success {
            slackSend channel: '#all-devops-practice',
                      color: 'good',
                      tokenCredentialId: 'slack-bot-token',
                      message: "✅ SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER} - ${env.BUILD_URL}"
        }
        failure {
            slackSend channel: '#all-devops-practice',
                      color: 'danger',
                      tokenCredentialId: 'slack-bot-token',
                      message: "❌ FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER} - ${env.BUILD_URL}"
        }
    }
}
